{
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.unstable", "deno.window", "ES2022", "DOM"]
  },
  "unstable": ["kv"],
  "nodeModulesDir": "auto",
  "imports": {
    "@barter.game/protocol": "./packages/protocol/src/index.ts",
    "@noble/ed25519": "npm:@noble/ed25519@^3.1.0",
    "@noble/hashes/": "npm:/@noble/hashes@^2.2.0/",
    "@scure/base": "npm:@scure/base@^2.2.0",
    "ulid": "npm:ulid@^2.3.0"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "test": {
    "include": [
      "packages/protocol/test-deno/*.deno-test.ts",
      "apps/bank/**/*.test.ts",
      "apps/bank/**/*.deno-test.ts"
    ]
  },
  "deploy": {
    "org": "ai-1st",
    "app": "barter-game-banks"
  }
}


























