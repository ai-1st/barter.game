{
  "name": "barter.game",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "bun --filter '@barter.game/protocol' test",
    "test:deno": "deno test --allow-read --allow-write --allow-env --allow-net",
    "test:all": "bun run test && bun run test:deno",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "build:website": "cd website && hugo",
    "deploy:website": "cd website && hugo --gc --minify && netlify deploy --prod --dir=public"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "latest"
  }
}
